---
interface Props {
	title?: string;
	description?: string;
	/** Absolute URL to the OG/Twitter card image (1200×630 recommended) */
	ogImage?: string;
	/** 'website' for homepage/projects, 'article' for blog posts */
	ogType?: 'website' | 'article';
	/** Full canonical URL for this page */
	canonicalUrl?: string;
	/** Extra Open Graph fields used by articles */
	article?: {
		author?: string;
		publishedTime?: string;
		tags?: string[];
	};
}

const {
	title = 'Sonu Gupta | Portfolio',
	description = 'Senior Software Engineer and Full Stack Developer portfolio.',
	ogImage = '/og-default.svg',
	ogType = 'website',
	canonicalUrl,
	article
} = Astro.props;

const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? '';
const resolvedCanonical = canonicalUrl ?? (siteUrl ? siteUrl + Astro.url.pathname : undefined);
const resolvedOgImage = ogImage.startsWith('http') ? ogImage : siteUrl + ogImage;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />

		<!-- Favicons & PWA -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#2563eb" />

		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		{resolvedCanonical && <link rel="canonical" href={resolvedCanonical} />}

		<!-- Open Graph -->
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={resolvedOgImage} />
		{resolvedCanonical && <meta property="og:url" content={resolvedCanonical} />}
		<meta property="og:site_name" content="Sonu Gupta" />
		{ogType === 'article' && article?.author && <meta property="article:author" content={article.author} />}
		{ogType === 'article' && article?.publishedTime && <meta property="article:published_time" content={article.publishedTime} />}
		{ogType === 'article' && article?.tags?.map((tag) => <meta property="article:tag" content={tag} />)}

		<!-- Twitter / X Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={resolvedOgImage} />
		<meta name="twitter:creator" content="@sonugpc" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<main class="page-bg">
			<slot />
		</main>
		<script is:inline>
			(() => {
				const storageKey = 'theme-preference';
				const root = document.documentElement;
				const body = document.body;

				const applyTheme = (theme) => {
					root.classList.toggle('dark', theme === 'dark');
					body.classList.toggle('dark', theme === 'dark');
				};

				const storedTheme = localStorage.getItem(storageKey);
				const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				applyTheme(storedTheme ?? (systemDark ? 'dark' : 'light'));

				document.addEventListener('click', (event) => {
					const target = event.target;
					if (!(target instanceof Element)) {
						return;
					}

					const toggle = target.closest('[data-theme-toggle]');
					if (!toggle) {
						return;
					}

					const nextTheme = body.classList.contains('dark') ? 'light' : 'dark';
					applyTheme(nextTheme);
					localStorage.setItem(storageKey, nextTheme);
				});
			})();
		</script>
	</body>
</html>

<style>
	:global(:root) {
		--page-bg: #ffffff;
		--text-main: #0f172a;
	}

	:global(html.dark) {
		--page-bg: #0b1020;
		--text-main: #e5e7eb;
	}

	:global(*) {
		box-sizing: border-box;
	}

	:global(html),
	:global(body) {
		margin: 0;
		min-height: 100%;
		font-family: 'Outfit', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		color: var(--text-main);
		background: var(--page-bg);
		transition: background-color 240ms ease, color 240ms ease;
	}

	:global(html) {
		scroll-behavior: smooth;
	}

	.page-bg {
		min-height: 100vh;
		width: 100%;
		padding: 2rem 2.25rem;
		background: var(--page-bg);
		transition: background-color 240ms ease;
	}

	@media (max-width: 900px) {
		.page-bg {
			padding: 1rem 1.1rem;
		}
	}
</style>
