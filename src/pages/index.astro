---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const blogPosts = (await getCollection('blog')).sort((a, b) => a.data.order - b.data.order);

const toSlug = (entryId: string) => entryId.replace(/\.mdx$/, '');

const featuredProject = projects.find((project) => project.data.featured) ?? projects[0];
const featuredProjectSlug = toSlug(featuredProject.id);
const gridProjects = projects.filter((project) => toSlug(project.id) !== featuredProjectSlug);
const techCards = ['TypeScript', 'Node.js', 'Angular', 'React', 'AWS', 'Firebase'];
---

<Layout title="Sonu Gupta | Portfolio" description="Senior Software Engineer portfolio website.">
	<div class="site-shell">
		<div class="sticky-nav">
			<div class="nav-inner">
				<SiteHeader activeSection="about" mode="buttons" />
			</div>
		</div>

		<section class="section" id="about" data-section="about">
			<div class="hero-content reveal">
				<h1>Hi, I&apos;m Sonu Gupta</h1>
				<p class="hero-subtitle">Senior Software Engineer | Full Stack &amp; AI Integrations</p>
				<p class="hero-description">
					I engineer intelligent systems that automate workflows, improve user experiences, and scale
					products from idea to production.
				</p>
				<div class="hero-actions">
					<button class="primary nav-trigger" data-target="projects" type="button">
						<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h7v7H4Zm9 0h7v7h-7ZM4 13h7v7H4Zm9 3h7v4h-7Zm0-3h7v2h-7Z"></path></svg>
						View Projects
					</button>
					<a class="secondary" href="https://github.com/sonugpc/" target="_blank" rel="noreferrer">
						<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a1 1 0 0 1 1 1v8.59l2.3-2.3a1 1 0 1 1 1.4 1.42l-4 4a1 1 0 0 1-1.4 0l-4-4a1 1 0 1 1 1.4-1.42L11 12.6V4a1 1 0 0 1 1-1ZM5 19a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H6a1 1 0 0 1-1-1Z"></path></svg>
						Download Resume
					</a>
				</div>
			</div>

			<div class="about-details reveal" style="--reveal-delay: 150ms">
				<h2>What I do</h2>
				<p>
					I build production-ready web and mobile products using modern frontend and backend stacks.
					My focus is clean architecture, automation, and integrating AI capabilities into real business
					flows.
				</p>

				<h3>Tech I Work With</h3>
				<div class="tech-grid">
					{
						techCards.map((tech, i) => (
							<article class="tech-item reveal" style={`--reveal-delay: ${150 + i * 60}ms`}>
								<span>{tech.slice(0, 2).toUpperCase()}</span>
								<p>{tech}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section" id="projects" data-section="projects">
			<div class="section-heading reveal">
				<h2>Projects</h2>
				<p class="section-sub">Selected work from 10+ years of product engineering.</p>
			</div>
			<div class="featured reveal" style="--reveal-delay: 80ms">
				<img src={featuredProject.data.image} alt={featuredProject.data.title} loading="lazy" />
				<div class="featured-content">
					<h2>{featuredProject.data.title}</h2>
					<p>{featuredProject.data.description}</p>
					<div class="project-actions">
						<a class="primary" href={`/projects/${featuredProjectSlug}`}>View Details</a>
						<a class="text-link" href={featuredProject.data.liveUrl} target="_blank" rel="noreferrer">Open Live</a>
					</div>
				</div>
			</div>

			<div class="project-grid">
				{
					gridProjects.map((project, i) => (
						<article class={`project-card reveal ${project.data.status === 'coming-soon' ? 'muted' : ''}`} style={`--reveal-delay: ${i * 70}ms`}>
							<h3>{project.data.title}</h3>
							<p>{project.data.shortDescription}</p>
							<a href={`/projects/${toSlug(project.id)}`}>
								{project.data.status === 'coming-soon' ? 'Coming Soon' : 'View Project'}
							</a>
						</article>
					))
				}
			</div>
		</section>

		<section class="section" id="blog" data-section="blog">
			<div class="blog-shell">
				<div class="section-heading reveal">
					<h2>Latest Writing</h2>
					<p class="section-sub">I write about product engineering, scalable systems, and practical AI integration patterns.</p>
				</div>

				<div class="blog-grid">
					{
						blogPosts.map((post, i) => (
							<article class="blog-card reveal" style={`--reveal-delay: ${i * 80}ms`}>
								<img src={post.data.featuredImage} alt={post.data.title} loading="lazy" />
								<h3>{post.data.title}</h3>
								<p>{post.data.excerpt}</p>
								<div class="meta-list">
									<p>
										<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a5 5 0 1 0-5-5 5 5 0 0 0 5 5Zm0 2c-4.42 0-8 2-8 4.5V21h16v-2.5c0-2.5-3.58-4.5-8-4.5Z"></path></svg>
										{post.data.author}
									</p>
									<p>
										<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h1a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h1V3a1 1 0 0 1 1-1Zm12 8H5v9h14Zm-3 3v2H8v-2Z"></path></svg>
										{post.data.publishedAt}
									</p>
									<p>
										<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16a1 1 0 0 1 1 1v2H3V6a1 1 0 0 1 1-1Zm-1 5h18v8a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1Zm4 2v2h6v-2Z"></path></svg>
										{post.data.topic}
									</p>
								</div>
								<a href={`/blog/${toSlug(post.id)}`}>Read Article</a>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section" id="contact" data-section="contact">
			<div class="contact-content reveal">
				<h2>Let&apos;s Work Together</h2>
				<p>
					I&apos;m always excited to collaborate, innovate, and build meaningful solutions. Whether you have
					a project, job opportunity, or just want to connect — let&apos;s talk.
				</p>
				<a class="primary" href="mailto:hello@sonugupta.dev">Get in Touch</a>
			</div>
		</section>

		<footer class="footer">© 2026 Sonu Gupta. All rights reserved.</footer>
	</div>
</Layout>

<script>
	const navTabs = document.querySelectorAll('.section-tabs .tab[data-target]');
	const actionTabs = document.querySelectorAll('.nav-trigger[data-target]');
	const sections = document.querySelectorAll('.section[data-section]');
	const slider = document.querySelector('.tab-slider');
	const stickyNav = document.querySelector('.sticky-nav');

	// Add shadow to sticky nav when page is scrolled
	window.addEventListener('scroll', () => {
		stickyNav?.classList.toggle('is-scrolled', window.scrollY > 10);
	}, { passive: true });

	function setSlider(activeTab) {
		if (!slider || !activeTab) return;
		slider.style.width = `${activeTab.offsetWidth}px`;
		slider.style.transform = `translateX(${activeTab.offsetLeft}px)`;
	}

	function setActiveTab(sectionId) {
		navTabs.forEach((tab) => {
			const isActive = tab.dataset.target === sectionId;
			tab.classList.toggle('is-active', isActive);
			if (isActive) setSlider(tab);
		});
	}

	function scrollToSection(sectionId) {
		const target = document.getElementById(sectionId);
		if (!target) return;
		const navH = stickyNav?.offsetHeight ?? 0;
		const top = target.getBoundingClientRect().top + window.scrollY - navH - 16;
		window.scrollTo({ top, behavior: 'smooth' });
	}

	// Tab / action button clicks → smooth scroll to section
	[...navTabs, ...actionTabs].forEach((tab) => {
		tab.addEventListener('click', () => {
			if (tab.dataset.target) scrollToSection(tab.dataset.target);
		});
	});

	// Update active tab as sections scroll into view
	const navH = stickyNav?.offsetHeight ?? 80;
	const sectionObserver = new IntersectionObserver(
		(entries) => {
			const visible = entries.filter((e) => e.isIntersecting);
			if (!visible.length) return;
			const topmost = visible.reduce((a, b) =>
				a.boundingClientRect.top < b.boundingClientRect.top ? a : b
			);
			const id = topmost.target.dataset.section ?? '';
			if (id) setActiveTab(id);
		},
		{ rootMargin: `-${navH + 10}px 0px -40% 0px`, threshold: 0 }
	);
	sections.forEach((s) => sectionObserver.observe(s));

	// Reveal animations — fade + slide up on scroll into view
	const revealObserver = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (!entry.isIntersecting) return;
				const el = entry.target;
				el.classList.add('is-visible');
				// After animation completes, remove reveal classes so hover transitions work normally
				const delayStr = getComputedStyle(el).getPropertyValue('--reveal-delay').trim();
				const delay = parseFloat(delayStr) || 0;
				setTimeout(() => el.classList.remove('reveal', 'is-visible'), 700 + delay);
				revealObserver.unobserve(el);
			});
		},
		{ threshold: 0.08 }
	);
	document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));

	// Initial active tab + slider position
	const firstActive = document.querySelector('.section-tabs .tab.is-active');
	if (firstActive instanceof HTMLElement) setSlider(firstActive);

	// If navigated with hash, scroll to that section
	const hash = window.location.hash.replace('#', '');
	if (hash && document.getElementById(hash)) {
		setTimeout(() => scrollToSection(hash), 80);
	}

	window.addEventListener('resize', () => {
		const active = document.querySelector('.section-tabs .tab.is-active');
		if (active instanceof HTMLElement) setSlider(active);
	});
</script>

<style>
	.site-shell {
		--surface-1: #ffffff;
		--surface-2: #f3f5f8;
		--surface-3: #eaedf3;
		--border-1: #dde2eb;
		--text-1: #0f172a;
		--text-2: #334155;
		--tab-bg: #eceff2;
		--primary: #2563eb;
		width: min(100%, 1240px);
		margin: 0 auto;
		transition: color 220ms ease;
	}

	:global(body.dark) .site-shell {
		--surface-1: #121a30;
		--surface-2: #17223d;
		--surface-3: #1d2a49;
		--border-1: #2b3857;
		--text-1: #e5e7eb;
		--text-2: #c3cede;
		--tab-bg: #1b2742;
		--primary: #3b82f6;
	}

	/* ── Sticky nav ─────────────────────── */
	.sticky-nav {
		position: sticky;
		top: 0;
		z-index: 100;
		/* Break out of the max-width site-shell to span full viewport */
		width: 100vw;
		margin-left: calc(50% - 50vw);
		background: var(--page-bg, #ffffff);
		border-bottom: 1px solid transparent;
		transition: border-color 240ms ease, box-shadow 240ms ease;
	}

	.nav-inner {
		width: min(100%, 1240px);
		margin: 0 auto;
		padding: 0.5rem 1.5rem;
	}

	.sticky-nav.is-scrolled {
		border-color: var(--border-1);
		box-shadow: 0 2px 20px rgba(15, 23, 42, 0.07);
	}

	/* ── Sections ───────────────────────── */
	.section {
		padding: 6rem 0;
		border-bottom: 1px solid var(--border-1);
	}

	.section:last-of-type {
		border-bottom: none;
	}

	.section-heading {
		margin-bottom: 2.5rem;
	}

	.section-heading h2 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 800;
		letter-spacing: -0.02em;
		color: var(--text-1);
	}

	.section-sub {
		margin: 0.5rem 0 0;
		color: var(--text-2);
		font-size: 1.05rem;
		line-height: 1.6;
	}

	/* ── Scroll-reveal animation ────────── */
	.reveal {
		opacity: 0;
		transform: translateY(26px);
	}

	.reveal.is-visible {
		animation: revealUp 680ms cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: var(--reveal-delay, 0ms);
	}

	@keyframes revealUp {
		from {
			opacity: 0;
			transform: translateY(26px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.hero-content {
		max-width: 760px;
		margin: 4rem auto 0;
		text-align: center;
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 5vw, 4rem);
		font-weight: 800;
		letter-spacing: -0.02em;
		color: var(--text-1);
	}

	.hero-subtitle {
		margin: 0.75rem 0;
		font-size: clamp(1.1rem, 2vw, 2rem);
		font-weight: 500;
		color: var(--text-2);
	}

	.hero-description {
		margin: 0 auto;
		max-width: 560px;
		color: var(--text-2);
		font-size: 1.05rem;
		line-height: 1.7;
	}

	.hero-actions,
	.project-actions,
	.contact-content .primary {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.8rem;
		margin-top: 1.5rem;
	}

	.primary,
	.secondary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
		padding: 0.7rem 1.4rem;
		border-radius: 999px;
		font-weight: 500;
		text-decoration: none;
		cursor: pointer;
		transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease, border-color 180ms ease;
	}

	.primary svg,
	.secondary svg {
		width: 0.95rem;
		height: 0.95rem;
		fill: currentColor;
	}

	.primary:hover,
	.secondary:hover,
	.project-card:hover,
	.blog-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 18px rgba(30, 41, 59, 0.12);
	}

	.primary {
		background: var(--primary);
		border: 1px solid var(--primary);
		color: #ffffff;
	}

	.secondary {
		border: 1px solid var(--border-1);
		color: var(--text-1);
		background: var(--surface-1);
	}

	.about-details {
		max-width: 620px;
		margin: 4rem auto 0;
		text-align: center;
	}

	.about-details h2,
	.about-details h3 {
		margin: 0 0 0.8rem;
		font-size: 2rem;
		color: var(--text-1);
	}

	.about-details p {
		margin: 0 auto;
		line-height: 1.75;
		color: var(--text-2);
	}

	.about-details h3 {
		margin-top: 2.4rem;
		font-size: 1.7rem;
	}

	.tech-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.9rem;
		margin-top: 1rem;
	}

	.tech-item {
		padding: 1rem;
		border-radius: 12px;
		background: var(--surface-2);
		text-align: center;
		border: 1px solid var(--border-1);
	}

	.tech-item span {
		display: grid;
		place-items: center;
		margin: 0 auto 0.5rem;
		width: 2rem;
		height: 2rem;
		border-radius: 8px;
		background: #dbeafe;
		font-size: 0.75rem;
		font-weight: 700;
		color: #1d4ed8;
	}

	.tech-item p {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--text-1);
	}

	.featured {
		display: grid;
		grid-template-columns: 1.35fr 1fr;
		gap: 1rem;
		align-items: stretch;
	}

	.featured img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 10px;
		border: 1px solid var(--border-1);
	}

	.featured-content {
		padding: 0.5rem;
	}

	.featured-content h2 {
		margin: 0;
		font-size: 1.65rem;
		color: var(--text-1);
	}

	.featured-content p {
		margin: 0.8rem 0;
		line-height: 1.65;
		color: var(--text-2);
	}

	.text-link {
		font-weight: 600;
		color: var(--text-1);
		text-decoration: none;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.5rem;
	}

	.project-card {
		padding: 1rem;
		border-radius: 12px;
		min-height: 180px;
		background: var(--surface-2);
		border: 1px solid var(--border-1);
		transition: transform 180ms ease, box-shadow 180ms ease;
	}

	.project-card h3 {
		margin: 0;
		font-size: 1.2rem;
		color: var(--text-1);
	}

	.project-card p {
		margin: 0.75rem 0;
		font-size: 0.95rem;
		line-height: 1.5;
		color: var(--text-2);
	}

	.project-card a {
		color: var(--text-1);
		font-weight: 600;
		text-decoration: none;
	}

	.blog-shell {
		width: 100%;
	}

	.blog-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.blog-card {
		padding: 1.1rem;
		border-radius: 14px;
		background: var(--surface-1);
		border: 1px solid var(--border-1);
		transition: transform 180ms ease, box-shadow 180ms ease;
	}

	.blog-card img {
		width: 100%;
		height: 170px;
		object-fit: cover;
		border-radius: 10px;
		border: 1px solid var(--border-1);
		margin-bottom: 0.8rem;
	}

	.blog-card h3 {
		margin: 0;
		font-size: 1.25rem;
		color: var(--text-1);
	}

	.blog-card p {
		margin: 0.6rem 0;
		line-height: 1.6;
		color: var(--text-2);
	}

	.meta-list {
		display: grid;
		gap: 0.25rem;
	}

	.meta-list p {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.88rem;
		margin: 0;
	}

	.meta-list svg {
		width: 0.85rem;
		height: 0.85rem;
		fill: currentColor;
	}

	.blog-card a {
		display: inline-block;
		margin-top: 0.9rem;
		font-weight: 600;
		color: var(--primary);
		text-decoration: none;
	}

	.project-card.muted {
		opacity: 0.76;
	}

	.contact-content {
		max-width: 820px;
		margin: 3rem auto;
		text-align: center;
	}

	.contact-content h2 {
		margin: 0;
		font-size: clamp(2.2rem, 5vw, 4.25rem);
		font-weight: 800;
		letter-spacing: -0.02em;
		color: var(--text-1);
	}

	.contact-content p {
		max-width: 560px;
		margin: 1rem auto 0;
		font-size: 1.2rem;
		line-height: 1.7;
		color: var(--text-2);
	}

	.contact-content .primary {
		margin-top: 1.5rem;
	}

	.footer {
		padding: 2.5rem 0;
		text-align: center;
		font-size: 0.85rem;
		color: var(--text-2);
	}

	@media (max-width: 1024px) {
		.featured {
			grid-template-columns: 1fr;
		}

		.project-grid,
		.blog-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.section {
			padding: 4rem 0;
		}

		.project-grid,
		.tech-grid,
		.blog-grid {
			grid-template-columns: 1fr;
		}

		.hero-actions,
		.project-actions {
			flex-wrap: wrap;
		}
	}
</style>
