---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	const toSlug = (entryId: string) => entryId.replace(/\.mdx$/, '');

	return projects.map((project) => ({
		params: { slug: toSlug(project.id) },
		props: { project }
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout
	title={`${project.data.title} | Sonu Gupta`}
	description={project.data.shortDescription}
	ogType="website"
	ogImage={project.data.image}
>
	<div class="project-page">
		<SiteHeader activeSection="projects" mode="links" />

		<nav class="breadcrumb" aria-label="Breadcrumb">
			<a href="/">Home</a>
			<span>/</span>
			<a href="/?section=projects">Projects</a>
			<span>/</span>
			<p>{project.data.title}</p>
		</nav>

		<section class="project-hero">
			<img src={project.data.image} alt={project.data.title} loading="lazy" />
			<div class="hero-content">
				<p class="period">{project.data.period}</p>
				<h1>{project.data.title}</h1>
				<p class="intro">{project.data.description}</p>
				<div class="actions">
					{project.data.liveUrl !== '#' && <a class="primary" href={project.data.liveUrl} target="_blank" rel="noreferrer">Open Live</a>}
					{project.data.githubUrl && <a class="secondary" href={project.data.githubUrl} target="_blank" rel="noreferrer">View GitHub</a>}
				</div>
			</div>
		</section>

		<section class="content-grid">
			<article class="card">
				<h2>Overview</h2>
				<p>{project.data.shortDescription}</p>
			</article>
			<article class="card">
				<h2>Tech Stack</h2>
				<ul class="chips">
					{project.data.tech.map((tech) => <li>{tech}</li>)}
				</ul>
			</article>
		</section>

		<section class="card highlights">
			<h2>Key Highlights</h2>
			<ul>
				{project.data.highlights.map((item) => <li>{item}</li>)}
			</ul>
		</section>

		<section class="card notes">
			<h2>Project Notes</h2>
			<div class="notes-content">
				<Content />
			</div>
		</section>
	</div>
</Layout>

<style>
	.project-page {
		--surface-1: #ffffff;
		--surface-2: #f3f5f8;
		--border-1: #dde2eb;
		--text-1: #0f172a;
		--text-2: #334155;
		--primary: #2563eb;
		width: min(100%, 1240px);
		margin: 0 auto;
	}

	:global(body.dark) .project-page {
		--surface-1: #121a30;
		--surface-2: #17223d;
		--border-1: #2b3857;
		--text-1: #e5e7eb;
		--text-2: #c3cede;
		--primary: #3b82f6;
	}


	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		margin: 1rem 0;
		font-size: 0.95rem;
	}

	.breadcrumb a,
	.breadcrumb p,
	.breadcrumb span {
		margin: 0;
		text-decoration: none;
		color: var(--text-2);
	}

	.breadcrumb p {
		color: var(--text-1);
		font-weight: 600;
	}

	.project-hero {
		display: grid;
		grid-template-columns: 1.15fr 1fr;
		gap: 1rem;
	}

	.project-hero img {
		width: 100%;
		height: 100%;
		min-height: 320px;
		object-fit: cover;
		border-radius: 14px;
		border: 1px solid var(--border-1);
	}

	.hero-content {
		padding: 1.2rem;
		border-radius: 14px;
		background: var(--surface-1);
		border: 1px solid var(--border-1);
	}

	.period {
		margin: 0;
		font-weight: 500;
		color: var(--text-2);
	}

	h1 {
		margin: 0.45rem 0;
		font-size: clamp(2rem, 5vw, 3.4rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		color: var(--text-1);
	}

	.intro {
		margin: 0;
		line-height: 1.7;
		color: var(--text-2);
	}

	.actions {
		display: flex;
		gap: 0.8rem;
		margin-top: 1.1rem;
	}

	.primary,
	.secondary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.7rem 1.2rem;
		border-radius: 999px;
		font-weight: 500;
		text-decoration: none;
	}

	.primary {
		color: #ffffff;
		border: 1px solid var(--primary);
		background: var(--primary);
	}

	.secondary {
		color: var(--text-1);
		border: 1px solid var(--border-1);
		background: var(--surface-1);
	}

	.content-grid {
		margin-top: 1rem;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.card {
		border-radius: 14px;
		padding: 1.1rem;
		background: var(--surface-1);
		border: 1px solid var(--border-1);
	}

	h2 {
		margin: 0;
		color: var(--text-1);
	}

	.card p {
		line-height: 1.7;
		color: var(--text-2);
	}

	.chips {
		list-style: none;
		padding: 0;
		margin: 1rem 0 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
	}

	.chips li {
		padding: 0.35rem 0.8rem;
		border-radius: 999px;
		background: var(--surface-2);
		border: 1px solid var(--border-1);
		font-size: 0.88rem;
		color: var(--text-2);
	}

	.highlights {
		margin-top: 1rem;
	}

	.notes {
		margin-top: 1rem;
	}

	.highlights ul {
		margin: 1rem 0 0;
		padding-left: 1.2rem;
		line-height: 1.7;
		color: var(--text-2);
	}

	.notes-content :global(p) {
		margin: 0 0 1rem;
		line-height: 1.8;
		color: var(--text-2);
	}

	.notes-content :global(p:last-child) {
		margin-bottom: 0;
	}

	@media (max-width: 920px) {
		.project-hero,
		.content-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
